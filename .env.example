# Backend
BACKEND_TOKEN=change-me-local-token
DATA_DIR=./data
LOG_LEVEL=INFO

# LLM provider
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Frontend
# NOTE: VITE_BACKEND_TOKEN is compiled into the JS bundle at build time.
# It prevents casual access but is NOT a real security credential.
VITE_API_BASE_URL=http://localhost:8000
VITE_BACKEND_TOKEN=change-me-local-token

# Ollama (only needed when LLM_PROVIDER=ollama)
# Run Ollama separately and set the base URL here.
# OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434
